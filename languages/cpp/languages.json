{
  "cpp": {
    "extensions": [
      ".cpp",
      ".cc",
      ".cxx",
      ".h",
      ".hpp",
      ".hxx"
    ],
    "grammar": "grammar/parser.wasm",
    "lsp_server": {
      "command": "clangd",
      "args": [],
      "workspace_markers": ["compile_commands.json", ".clangd", "CMakeLists.txt", "Makefile"],
      "install": {
        "method": "system",
        "package": "clangd"
      }
    }
  }
}
